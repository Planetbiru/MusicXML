{
    "name": "planetbiru/musicxml",
    "description": "A PHP library to convert MIDI files to MusicXML and DAWPRoject, and render them as PDF or SVG.",
    "type": "library",
    "keywords": [
        "midi",
        "musicxml",
        "dawproject",
        "pdf",
        "svg",
        "music",
        "notation",
        "score",
        "fpdf"
    ],
    "homepage": "https://www.planetbiru.com",
    "license": "MIT",
    "authors": [
        {
            "name": "Planetbiru",
            "homepage": "https://www.planetbiru.com"
        }
    ],
    "require": {
        "php": ">=5.6",
        "fpdf/fpdf": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "MusicXML\\": "src/MusicXML/",
            "Midi\\": "src/Midi/",
            "DAWProject\\": "src/DAWProject/"
        }
    },
    "config": {
        "vendor-dir": "vendor"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
